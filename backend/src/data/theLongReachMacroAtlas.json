        "barrierAwareTraversal": true,
        "routeContinuityRequiredWhenTagged": true,
        "rules": [
            "Nearby frontier-capable nodes within the same macro context inherit directional terrain trends unless explicit stronger local override exists.",
            "Barrier-linked adjacencies must preserve traversal semantics (blocked, constrained, seasonal, hazardous) during future-node generation.",
            "When a local frontier anchor references a continuity route, generated nodes should continue route identity before introducing branch variation.",
            "Western-context expansions should retain west-coast cliff/fiord pressure and not abruptly flatten into unrelated broad plains.",
            "Eastern-context expansions should remain broader and lower-relief unless crossing a pass or ridge-linked barrier edge."
        ]
    }
